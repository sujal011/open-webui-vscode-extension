{
	"name": "open-webui-vscode",
	"displayName": "Open WebUI Agent",
	"description": "VS Code chat extension that reuses Open WebUI APIs, history, tools, knowledge, and model routing.",
	"version": "0.0.1",
	"publisher": "open-webui",
	"private": true,
	"engines": {
		"vscode": "^1.92.0",
		"node": ">=18.13.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onCommand:openWebuiAgent.openChat",
		"onView:openWebuiAgent.chat"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "openWebuiAgent.openChat",
				"title": "Open WebUI Agent: Open Chat"
			},
			{
				"command": "openWebuiAgent.signOut",
				"title": "Open WebUI Agent: Sign Out"
			},
			{
				"command": "openWebuiAgent.showLogs",
				"title": "Open WebUI Agent: Show Logs"
			}
		],
		"configuration": {
			"title": "Open WebUI Agent",
			"properties": {
				"openWebuiAgent.baseUrl": {
					"type": "string",
					"default": "http://localhost:8080",
					"description": "Base URL for the Open WebUI server."
				},
				"openWebuiAgent.defaultModel": {
					"type": "string",
					"default": "",
					"description": "Optional model id to preselect in new chats."
				},
				"openWebuiAgent.enableWorkspaceTools": {
					"type": "boolean",
					"default": true,
					"description": "Expose VS Code workspace tool metadata to Open WebUI chat requests."
				}
			}
		},
		"viewsContainers": {
			"activitybar": [
				{
					"id": "openWebuiAgent",
					"title": "Open WebUI",
					"icon": "media/icon.svg"
				}
			]
		},
		"views": {
			"openWebuiAgent": [
				{
					"id": "openWebuiAgent.chat",
					"name": "Chat",
					"type": "webview"
				}
			]
		}
	},
	"scripts": {
		"build": "npm run sync:ui && npm run build:webview && npm run compile",
		"build:webview": "vite build",
		"compile": "node scripts/build-extension.mjs",
		"sync:ui": "node scripts/sync-open-webui-ui.mjs",
		"watch": "npm run build:webview -- --watch & node scripts/build-extension.mjs --watch",
		"check": "tsc -p ./tsconfig.json --noEmit && npm run sync:ui && vite build"
	},
	"dependencies": {
		"@azure/msal-browser": "^4.30.0",
		"@codemirror/lang-javascript": "^6.2.5",
		"@codemirror/lang-python": "^6.2.1",
		"@codemirror/language-data": "^6.5.2",
		"@codemirror/theme-one-dark": "^6.1.3",
		"@floating-ui/dom": "^1.7.2",
		"@huggingface/transformers": "^3.8.1",
		"@joplin/turndown-plugin-gfm": "^1.0.67",
		"@mediapipe/tasks-vision": "^0.10.35",
		"@pyscript/core": "^0.4.56",
		"@sveltejs/svelte-virtual-list": "^3.0.1",
		"@sveltejs/vite-plugin-svelte": "^4.0.0",
		"@tiptap/core": "^3.0.7",
		"@tiptap/extension-bubble-menu": "^3.0.7",
		"@tiptap/extension-code": "^3.0.7",
